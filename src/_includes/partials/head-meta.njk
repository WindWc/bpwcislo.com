<link rel="canonical" href="{{ canonicalUrl | default(site.url + page.url) }}">

<link rel="icon" href="/assets/favicon/favicon.ico" sizes="any">
<link rel="icon" href="/assets/favicon/favicon.svg" type="image/svg+xml">
<link rel="apple-touch-icon" href="/assets/favicon/apple-touch-icon.png">

<meta property="og:site_name" content="{{ site.title }}">
<meta property="og:type" content="{{ ogType | default('website') }}">
<meta property="og:title" content="{{ ogTitle | default(pageTitle) | default(title + ' | ' + site.title) | default(site.title + ' | ' + site.tagline) }}">
<meta property="og:description" content="{{ ogDescription | default(description | default(site.description)) }}">
<meta property="og:url" content="{{ ogUrl | default(site.url + page.url) }}">
<meta property="og:image" content="{{ ogImage | default(site.url + (featuredImage | default('/assets/images/og-share.jpg'))) }}">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
{% if ogType == "article" and date %}
<meta property="article:published_time" content="{{ date | dateISO }}">
<meta property="article:modified_time" content="{{ modified | default(date) | dateISO }}">
<meta property="article:author" content="{{ site.author.name }}">
<meta property="article:section" content="Building">
{% for tag in tags %}{% if tag != "post" %}<meta property="article:tag" content="{{ tag }}">
{% endif %}{% endfor %}{% endif %}

<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ ogTitle | default(pageTitle) | default(title + ' | ' + site.title) | default(site.title + ' | ' + site.tagline) }}">
<meta name="twitter:description" content="{{ ogDescription | default(description | default(site.description)) }}">
<meta name="twitter:image" content="{{ ogImage | default(site.url + (featuredImage | default('/assets/images/og-share.jpg'))) }}">
