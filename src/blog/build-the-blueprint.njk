<script>
(function() {
  /* ── Swim Lane Phase Filter ── */
  var filterBtns = document.querySelectorAll('.bp-phase-btn');
  var steps = document.querySelectorAll('.bp-step');

  filterBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      var phase = this.getAttribute('data-bp-phase');
      filterBtns.forEach(function(b) { b.classList.remove('bp-active'); });
      this.classList.add('bp-active');

      steps.forEach(function(step) {
        if (phase === 'all') {
          step.style.opacity = '1';
          step.style.transform = 'scale(1)';
        } else {
          var stepPhase = step.getAttribute('data-bp-step-phase');
          if (stepPhase === phase) {
            step.style.opacity = '1';
            step.style.transform = 'scale(1)';
          } else {
            step.style.opacity = '0.15';
            step.style.transform = 'scale(0.95)';
          }
        }
      });
    });
  });

  /* ── Lifecycle scroll trigger ── */
  var lifecycle = document.getElementById('bp-lifecycle');
  if (lifecycle) {
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          lifecycle.classList.add('bp-animate');
          observer.unobserve(lifecycle);
        }
      });
    }, { threshold: 0.3 });
    observer.observe(lifecycle);
  }
})();

/* ── Screen Blueprint Navigation ── */
function bpShowScreen(screenId) {
  var panels = document.querySelectorAll('.bp-screen-panel');
  var navItems = document.querySelectorAll('.bp-screen-nav-item');

  panels.forEach(function(p) { p.classList.remove('bp-screen-visible'); });
  navItems.forEach(function(n) { n.classList.remove('bp-screen-active'); });

  var target = document.getElementById('bp-screen-' + screenId);
  if (target) target.classList.add('bp-screen-visible');

  var nav = document.querySelector('[data-bp-screen="' + screenId + '"]');
  if (nav) nav.classList.add('bp-screen-active');

  /* Update URL bar */
  var route = target ? target.querySelector('.bp-screen-route') : null;
  var urlBar = document.querySelector('.bp-screens-url');
  if (route && urlBar) urlBar.textContent = 'app.arsflows.com' + route.textContent;
}
</script>
