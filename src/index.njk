{% block body_js %}
<script>
  const circleWrapper = document.querySelector('.circle-wrapper');
  const squareWrapper = document.querySelector('.square-wrapper');

  // Smooth expand/collapse for <details> elements
  document.querySelectorAll('.about-expandable').forEach(function(details) {
    details.querySelector('summary').addEventListener('click', function(e) {
      e.preventDefault();
      if (details.open) {
        details.classList.add('closing');
        setTimeout(function() {
          details.open = false;
          details.classList.remove('closing');
        }, 420);
      } else {
        details.open = true;
      }
    });
  });

  // Gentle mouse influence on floating shapes (site-wide)
  let mouseX = 0;
  let mouseY = 0;
  let targetMouseX = 0;
  let targetMouseY = 0;
  let currentScrollY = 0;
  let targetScrollY = 0;

  document.addEventListener('mousemove', (e) => {
    if (prefersReducedMotion) return;
    targetMouseX = (e.clientX / window.innerWidth - 0.5) * 2;
    targetMouseY = (e.clientY / window.innerHeight - 0.5) * 2;
  });

  window.addEventListener('scroll', () => {
    targetScrollY = window.scrollY;
  });

  function animateShapes() {
    if (prefersReducedMotion) {
      requestAnimationFrame(animateShapes);
      return;
    }

    mouseX += (targetMouseX - mouseX) * 0.03;
    mouseY += (targetMouseY - mouseY) * 0.03;
    currentScrollY += (targetScrollY - currentScrollY) * 0.08;

    var maxScroll = document.documentElement.scrollHeight - window.innerHeight;
    var scrollPct = maxScroll > 0 ? currentScrollY / maxScroll : 0;

    var circleTravel = window.innerHeight * 0.7;
    var squareTravel = window.innerHeight * 0.6;

    var circleParallaxY = scrollPct * circleTravel;
    var squareParallaxY = -scrollPct * squareTravel;

    var circleX = mouseX * 12;
    var circleY = circleParallaxY + mouseY * 12;

    var squareX = mouseX * -8;
    var squareY = squareParallaxY + mouseY * -8;

    circleWrapper.style.transform = `translate(${circleX}px, ${circleY}px)`;
    squareWrapper.style.transform = `translate(${squareX}px, ${squareY}px)`;

    requestAnimationFrame(animateShapes);
  }

  animateShapes();

  // Rotating words animation
  const rotatingWord = document.querySelector('.rotating-word');
  const words = ['effortless', 'scalable', 'magnetic', 'unstoppable', 'exceptional', 'alive'];
  let currentWordIndex = 0;

  function rotateWord() {
    rotatingWord.classList.add('fade-out');
    rotatingWord.classList.remove('fade-in');

    setTimeout(() => {
      currentWordIndex = (currentWordIndex + 1) % words.length;
      rotatingWord.textContent = words[currentWordIndex];
      rotatingWord.classList.remove('fade-out');
      rotatingWord.classList.add('fade-in');
    }, 200);
  }

  setInterval(rotateWord, 2500);

  // Magnetic fluid effect for buttons (hero only, disabled once scrolled past)
  const heroSection = document.querySelector('.hero');
  const heroButtons = heroSection.querySelectorAll('.btn, .hero-name-card');

  heroButtons.forEach(el => {
    el.classList.add('magnetic');

    el.addEventListener('mouseenter', () => {
      var pts = el.classList.contains('btn') ? 11 : 9;
      SiteScore.award(pts, 'hero-' + (el.classList.contains('btn') ? 'cta' : 'name'), 5000);
    });

    el.addEventListener('mousemove', (e) => {
      if (prefersReducedMotion) return;
      if (window.matchMedia('(max-width: 768px)').matches) return;
      if (window.scrollY > heroSection.offsetHeight * 0.5) return;

      const rect = el.getBoundingClientRect();
      const x = e.clientX - rect.left - rect.width / 2;
      const y = e.clientY - rect.top - rect.height / 2;

      const pull = 0.3;
      el.style.transform = `translate(${x * pull}px, ${y * pull}px)`;
    });

    el.addEventListener('mouseleave', () => {
      el.style.transform = '';
    });
  });

  // Scroll-triggered icon animations for service and essential cards
  (function() {
    var cards = document.querySelectorAll('.service-card, .essential-card');
    if (!cards.length) return;
    var triggerPoint = 0.6;
    var wasBelow = new Map();
    var serviceCards = document.querySelectorAll('.services-grid .service-card');
    var serviceStagger = 500;

    cards.forEach(function(card) { wasBelow.set(card, true); });

    function fireAnimation(card) {
      card.classList.remove('scroll-active');
      void card.offsetWidth;
      card.classList.add('scroll-active');
      setTimeout(function() { card.classList.remove('scroll-active'); }, 900);
    }

    function checkCards() {
      var threshold = window.innerHeight * triggerPoint;
      var serviceBatch = [];
      cards.forEach(function(card) {
        var rect = card.getBoundingClientRect();
        var isBelow = rect.top > threshold;
        var wasIt = wasBelow.get(card);

        if (wasIt !== isBelow) {
          var idx = Array.prototype.indexOf.call(serviceCards, card);
          if (idx > -1) {
            serviceBatch.push({ card: card, index: idx });
          } else {
            fireAnimation(card);
          }
        }

        wasBelow.set(card, isBelow);
      });
      serviceBatch.forEach(function(item) {
        setTimeout(function() { fireAnimation(item.card); }, item.index * serviceStagger);
      });
    }

    window.addEventListener('scroll', checkCards, { passive: true });
    checkCards();
  })();

  // Score: hover + click on nav links
  const navLinks = document.querySelectorAll('.nav-links a[href^="#"]');
  navLinks.forEach((link, i) => {
    link.addEventListener('mouseenter', () => {
      SiteScore.award(3, 'nav-hover-' + i, 5000);
    });
    link.addEventListener('click', () => {
      SiteScore.once(13, 'nav-click-' + i);
    });
  });

  // Scroll reveal animations
  if (!prefersReducedMotion) {
    const revealTargets = document.querySelectorAll(
      '.what-i-do .section-intro, .service-card, .projects .section-intro, .project-content, .project-gallery, .testimonials .section-intro, .testimonial-card, .partners .section-intro, .partner-card, .about-text, .essential-card, .contact h2, .contact p, .flowform'
    );

    revealTargets.forEach(el => el.classList.add('reveal'));

    document.querySelectorAll('.services-grid, .projects-grid, .testimonials-grid, .partners-grid').forEach(grid => {
      const children = grid.querySelectorAll('.reveal');
      children.forEach((child, i) => {
        child.style.transitionDelay = `${i * 0.12}s`;
      });
    });

    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          setTimeout(() => { entry.target.style.transitionDelay = ''; }, 1000);
          revealObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -60px 0px' });

    revealTargets.forEach(el => revealObserver.observe(el));

    const scoreSections = document.querySelectorAll('section[id]');
    const sectionObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          SiteScore.once(21, 'section-' + entry.target.id);
        }
      });
    }, { threshold: 0.2 });
    scoreSections.forEach(s => sectionObserver.observe(s));
  }

  // Green highlight wipe tied to scroll position
  const outro = document.querySelector('.section-outro');
  if (outro) {
    function updateOutroHighlight() {
      const rect = outro.getBoundingClientRect();
      const vh = window.innerHeight;

      const onStart = vh;
      const onEnd = vh * 0.5;
      const onProgress = Math.max(0, Math.min(1, (onStart - rect.top) / (onStart - onEnd)));

      const offStart = vh * 0.5;
      const offEnd = vh * 0.15;
      const offProgress = Math.max(0, Math.min(1, (offStart - rect.top) / (offStart - offEnd)));

      if (offProgress > 0) {
        const size = (1 - offProgress) * 100;
        outro.style.backgroundSize = `${size}% 30%`;
        outro.style.backgroundPosition = `100% 85%`;
      } else {
        outro.style.backgroundSize = `${onProgress * 100}% 30%`;
        outro.style.backgroundPosition = `0% 85%`;
      }
    }
    window.addEventListener('scroll', updateOutroHighlight, { passive: true });
    updateOutroHighlight();
  }

  // Scroll progress bar
  const scrollProgressBar = document.querySelector('.scroll-progress');
  if (scrollProgressBar) {
    window.addEventListener('scroll', () => {
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const progress = docHeight > 0 ? (window.scrollY / docHeight) * 100 : 0;
      scrollProgressBar.style.width = progress + '%';
    }, { passive: true });
  }

  // Animated stat counters
  const statCounters = document.querySelectorAll('.stat-counter');
  if (statCounters.length && !prefersReducedMotion) {
    const counterObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        const el = entry.target;
        const target = parseInt(el.dataset.target, 10);
        const suffix = el.dataset.suffix || '';
        const duration = 1400;
        const start = performance.now();

        function tick(now) {
          const elapsed = now - start;
          const progress = Math.min(elapsed / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          const current = Math.round(eased * target);
          el.textContent = current + suffix;
          if (progress < 1) requestAnimationFrame(tick);
        }

        requestAnimationFrame(tick);
        counterObserver.unobserve(el);
      });
    }, { threshold: 0.5 });

    statCounters.forEach(el => counterObserver.observe(el));
  }

  // Project gallery navigation + dot indicators
  document.querySelectorAll('.project-gallery').forEach(gallery => {
    const galleryTrack = gallery.querySelector('.project-gallery-track');
    const prevArrow = gallery.querySelector('.gallery-prev');
    const nextArrow = gallery.querySelector('.gallery-next');
    const slides = galleryTrack.querySelectorAll('.project-slide');
    if (!galleryTrack || !prevArrow || !nextArrow) return;

    const dotsContainer = document.createElement('div');
    dotsContainer.className = 'gallery-dots';
    const dots = [];
    slides.forEach((_, i) => {
      const dot = document.createElement('button');
      dot.className = 'gallery-dot' + (i === 0 ? ' active' : '');
      dot.setAttribute('aria-label', `Go to slide ${i + 1}`);
      dot.addEventListener('click', () => {
        slides[i].scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
        SiteScore.award(8, 'gal-dot', 2000);
      });
      dotsContainer.appendChild(dot);
      dots.push(dot);
    });
    gallery.querySelector('.project-gallery-nav').after(dotsContainer);

    slides.forEach(slide => {
      slide.style.cursor = 'pointer';
      slide.addEventListener('click', () => {
        const active = getActiveIndex();
        const trackRect = galleryTrack.getBoundingClientRect();
        const trackCenter = trackRect.left + trackRect.width / 2;
        const slideRect = slide.getBoundingClientRect();
        const slideCenter = slideRect.left + slideRect.width / 2;
        if (Math.abs(slideCenter - trackCenter) < 20) return;
        slide.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
      });
    });

    function getSlideWidth() {
      const slide = galleryTrack.querySelector('.project-slide');
      if (!slide) return 300;
      return slide.offsetWidth + 16;
    }

    function getActiveIndex() {
      const trackRect = galleryTrack.getBoundingClientRect();
      const center = trackRect.left + trackRect.width / 2;
      let closest = 0;
      let minDist = Infinity;
      slides.forEach((slide, i) => {
        const rect = slide.getBoundingClientRect();
        const slideCenter = rect.left + rect.width / 2;
        const dist = Math.abs(slideCenter - center);
        if (dist < minDist) { minDist = dist; closest = i; }
      });
      return closest;
    }

    function updateGalleryState() {
      prevArrow.disabled = galleryTrack.scrollLeft <= 5;
      nextArrow.disabled = galleryTrack.scrollLeft >= galleryTrack.scrollWidth - galleryTrack.clientWidth - 5;
      const active = getActiveIndex();
      dots.forEach((d, i) => d.classList.toggle('active', i === active));
    }

    prevArrow.addEventListener('click', () => {
      galleryTrack.scrollBy({ left: -getSlideWidth(), behavior: 'smooth' });
      SiteScore.award(8, 'gal-arrow', 2000);
    });

    nextArrow.addEventListener('click', () => {
      galleryTrack.scrollBy({ left: getSlideWidth(), behavior: 'smooth' });
      SiteScore.award(8, 'gal-arrow', 2000);
    });

    galleryTrack.addEventListener('scroll', updateGalleryState, { passive: true });
    galleryTrack.addEventListener('scroll', function() {
      SiteScore.award(9, 'gal-scroll', 3000);
    }, { passive: true });
    updateGalleryState();
  });

  // Scroll-triggered text reveal (blur-reveal for section headings)
  if (!prefersReducedMotion) {
    document.querySelectorAll('.text-reveal').forEach(el => {
      const allSpans = [];

      function wrapTextNodes(node) {
        const children = Array.from(node.childNodes);
        children.forEach(child => {
          if (child.nodeType === 3) {
            const frag = document.createDocumentFragment();
            child.textContent.split('').forEach(ch => {
              const span = document.createElement('span');
              span.className = 'scramble-letter' + (/\s/.test(ch) ? ' space' : '');
              span.textContent = ch;
              frag.appendChild(span);
              if (!/\s/.test(ch)) allSpans.push(span);
            });
            child.replaceWith(frag);
          } else if (child.nodeType === 1 && child.tagName !== 'BR') {
            wrapTextNodes(child);
          }
        });
      }

      wrapTextNodes(el);

      const textRevealObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (!entry.isIntersecting) return;
          allSpans.forEach((span, i) => {
            setTimeout(() => {
              span.classList.add('revealed');
            }, 80 + i * 35);
          });
          textRevealObserver.unobserve(entry.target);
        });
      }, { threshold: 0.3 });

      textRevealObserver.observe(el);
    });
  }

  // Cursor spotlight on dark sections
  if (!prefersReducedMotion) {
    document.querySelectorAll('.project-card--dark, .partners').forEach(section => {
      section.classList.add('cursor-spotlight');
      section.addEventListener('mousemove', (e) => {
        const rect = section.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        section.style.setProperty('--spot-x', x + 'px');
        section.style.setProperty('--spot-y', y + 'px');
      });
    });

    const spotStyle = document.createElement('style');
    spotStyle.textContent = `.cursor-spotlight::before { left: var(--spot-x, -300px); top: var(--spot-y, -300px); }`;
    document.head.appendChild(spotStyle);
  }

  // 3D tilt on testimonial + essential cards
  if (!prefersReducedMotion) {
    document.querySelectorAll('.testimonial-card, .essential-card').forEach(card => {
      card.addEventListener('mousemove', (e) => {
        const rect = card.getBoundingClientRect();
        const x = (e.clientX - rect.left) / rect.width - 0.5;
        const y = (e.clientY - rect.top) / rect.height - 0.5;
        card.style.transform = `perspective(800px) rotateY(${x * 8}deg) rotateX(${-y * 8}deg) translateY(-2px)`;
      });
      card.addEventListener('mouseleave', () => {
        card.style.transform = '';
      });
    });
  }

  // Score: hover on service, testimonial, essential, partner cards
  document.querySelectorAll('.service-card').forEach((c, i) => {
    c.addEventListener('mouseenter', () => SiteScore.award(7, 'svc-' + i, 5000));
  });
  document.querySelectorAll('.testimonial-card').forEach((c, i) => {
    c.addEventListener('mouseenter', () => SiteScore.award(8, 'tst-' + i, 5000));
  });
  document.querySelectorAll('.essential-card').forEach((c, i) => {
    c.addEventListener('mouseenter', () => SiteScore.award(5, 'ess-' + i, 5000));
  });
  document.querySelectorAll('.partner-name').forEach((c, i) => {
    c.addEventListener('mouseenter', () => SiteScore.award(3, 'prt-' + i, 5000));
  });

  // Hero text reveal on load
  (function() {
    if (prefersReducedMotion) return;
    const headline = document.querySelector('.hero-headline');
    if (!headline) return;

    const allSpans = [];

    function wrapTextNodes(node) {
      const children = Array.from(node.childNodes);
      children.forEach(child => {
        if (child.nodeType === 3) {
          const frag = document.createDocumentFragment();
          child.textContent.split('').forEach(ch => {
            const span = document.createElement('span');
            span.className = 'scramble-letter' + (/\s/.test(ch) ? ' space' : '');
            span.textContent = ch;
            frag.appendChild(span);
            if (!/\s/.test(ch)) allSpans.push(span);
          });
          child.replaceWith(frag);
        } else if (child.nodeType === 1 && child.tagName !== 'BR') {
          wrapTextNodes(child);
        }
      });
    }

    wrapTextNodes(headline);

    const totalRevealTime = 80 + allSpans.length * 35 + 350;

    allSpans.forEach((span, i) => {
      setTimeout(() => {
        span.classList.add('revealed');
      }, 80 + i * 35);
    });

    const heroTaglineEl = document.querySelector('.hero-tagline');
    const heroBtnEl = document.querySelector('.hero .btn');
    const taglineStrong = document.querySelector('.tagline-main strong');

    setTimeout(() => {
      if (heroTaglineEl) heroTaglineEl.classList.add('hero-revealed');
    }, totalRevealTime);

    setTimeout(() => {
      if (heroBtnEl) heroBtnEl.classList.add('hero-revealed');
    }, totalRevealTime + 200);

    if (taglineStrong && window.matchMedia('(max-width: 768px)').matches) {
      taglineStrong.style.transition = 'none';
      function scrollUnderline() {
        var rect = taglineStrong.getBoundingClientRect();
        var start = window.innerHeight * 0.8;
        var end = window.innerHeight * 0.45;
        var pct = Math.max(0, Math.min(1, (start - rect.top) / (start - end)));
        taglineStrong.style.backgroundSize = (pct * 100) + '% 22%';
      }
      window.addEventListener('scroll', scrollUnderline, { passive: true });
      scrollUnderline();
    } else {
      setTimeout(() => {
        if (taglineStrong) taglineStrong.classList.add('underline-visible');
      }, totalRevealTime + 500);
    }
  })();

  // ─── FlowForm — Multi-step lead qualification funnel ───
  (function() {
    const FF_SCREENS = [
      {
        id: 'ready_to_move',
        heading: "What's ready to move?",
        type: 'single',
        options: [
          "Turn something essential into something enjoyable",
          "I have a vision and I'm ready for a builder",
          "We've outgrown our current tools",
          "Guide me to technical clarity",
          "I'd rather just email you",
        ],
      },
      {
        id: 'building',
        heading: "What are we building?",
        sub: "Pick all that apply",
        type: 'multi',
        options: [
          "A website",
          "A web or mobile app",
          "AI or automation workflow",
          "Strategy and product roadmap",
          "Not sure yet — help me figure it out",
        ],
      },
      {
        id: 'stage',
        heading: "Where are you in the process?",
        type: 'single',
        options: [
          "Just an idea so far",
          "I have notes or a brief",
          "I have a prototype or MVP",
          "I'm live and ready to level up",
        ],
      },
      {
        id: 'urgency',
        heading: "How urgent is this?",
        type: 'single',
        options: [
          "I want to be thoughtful about this",
          "We needed this yesterday",
          "A few months out",
          "Not sure yet",
        ],
      },
      {
        id: 'budget',
        heading: "What's your budget comfort zone?",
        type: 'single',
        options: [
          "$10K or less",
          "$10K–$25K",
          "$25K–$50K",
          "$50K–$100K",
          "$100K+",
          "Not sure yet — let's talk",
        ],
      },
      {
        id: 'contact',
        heading: "Let's connect.",
        sub: "I read every submission myself.<br>You'll hear from me within 48 hours.",
        type: 'contact',
      },
      {
        id: 'confirmation',
        type: 'confirmation',
      },
    ];

    const TOTAL = FF_SCREENS.length;
    const ffCard = document.getElementById('ffCard');
    const ffProgress = document.getElementById('ffProgress');
    const ffStepLabel = document.getElementById('ffStepLabel');
    const ffBackWrap = document.getElementById('ffBackWrap');

    if (!ffCard) return;

    let step = 0;
    let direction = 1;
    let selections = {};
    let multiSelections = [];
    let contactData = { name: '', email: '', contact_pref: '', phone: '', one_thing: '' };
    let advanceTimer = null;
    let stepHistory = [0];

    function buildProgress() {
      ffProgress.innerHTML = '';
      for (let i = 0; i < TOTAL - 1; i++) {
        const bar = document.createElement('div');
        bar.className = 'flowform-progress-bar' + (i <= step ? ' active' : '');
        ffProgress.appendChild(bar);
      }
    }

    function render() {
      const screen = FF_SCREENS[step];
      const isConfirmation = screen.type === 'confirmation';

      ffProgress.style.display = isConfirmation ? 'none' : '';
      ffStepLabel.style.display = 'none';
      buildProgress();

      ffCard.style.border = isConfirmation ? 'none' : '';
      ffCard.style.boxShadow = isConfirmation ? 'none' : '';
      ffCard.style.background = isConfirmation ? 'transparent' : '';

      const animClass = direction > 0 ? 'ff-fade-up' : 'ff-fade-down';
      ffCard.className = 'flowform-card ' + animClass;

      if (screen.type === 'confirmation') {
        SiteScore.once(1111, 'ff-complete');
      } else if (step > 0) {
        SiteScore.once(33, 'ff-step-' + step);
      }

      let html = '';

      if (screen.heading) {
        html += '<div class="flowform-heading">' + screen.heading + '</div>';
        if (screen.sub) html += '<div class="flowform-sub">' + screen.sub + '</div>';
        else html += '<div style="margin-bottom: var(--space-6)"></div>';
      }

      if (screen.type === 'single' || screen.type === 'multi') {
        html += '<div class="flowform-options">';
        screen.options.forEach(function(opt, i) {
          const sel = screen.type === 'multi'
            ? multiSelections.indexOf(opt) !== -1
            : selections[screen.id] === opt;
          html += '<button class="flowform-option' + (sel ? ' selected' : '') + '" '
            + 'data-value="' + opt.replace(/"/g, '&quot;') + '" '
            + 'style="animation-delay: ' + (i * 60) + 'ms">'
            + '<span>' + opt + '</span>'
            + '<span class="flowform-option-indicator">'
            + (sel ? '<svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M2.5 5L4.5 7L7.5 3.5" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>' : '')
            + '</span>'
            + '</button>';
        });
        html += '</div>';

        if (screen.type === 'multi') {
          var hasBack = step > 0;
          html += '<div class="flowform-btn-row' + (hasBack ? '' : ' single-btn') + '">';
          if (hasBack) html += '<button class="flowform-back" id="ffBack">← Back</button>';
          html += '<button class="flowform-next-btn" id="ffMultiNext"'
            + (multiSelections.length === 0 ? ' disabled' : '')
            + '>Next →</button>';
          html += '</div>';
        } else if (screen.type === 'single' && step > 0) {
          html += '<div class="flowform-btn-row single-btn">';
          html += '<button class="flowform-back" id="ffBack">← Back</button>';
          html += '</div>';
        }
      }

      if (screen.type === 'contact') {
        html += '<div class="flowform-contact">'
          + '<input type="text" placeholder="Name" id="ffName" value="' + esc(contactData.name) + '">'
          + '<div id="ffNameErr"></div>'
          + '<input type="email" placeholder="Email" id="ffEmail" value="' + esc(contactData.email) + '">'
          + '<div id="ffEmailErr"></div>'
          + '<select id="ffPref">'
          + '<option value="" disabled ' + (!contactData.contact_pref ? 'selected' : '') + '>Preferred contact</option>'
          + '<option value="Email"' + (contactData.contact_pref === 'Email' ? ' selected' : '') + '>Email</option>'
          + '<option value="Phone"' + (contactData.contact_pref === 'Phone' ? ' selected' : '') + '>Phone</option>'
          + '</select>'
          + '<div id="ffPhoneWrap" style="' + (contactData.contact_pref === 'Phone' ? '' : 'display:none') + '">'
          + '<input type="tel" placeholder="Phone number" id="ffPhone" value="' + esc(contactData.phone) + '">'
          + '<div id="ffPhoneErr"></div>'
          + '</div>'
          + '<textarea placeholder="Anything else I should know?" id="ffOneThing" rows="3">' + esc(contactData.one_thing) + '</textarea>'
          + '<div class="flowform-btn-row">'
          + '<button class="flowform-back" id="ffBack">← Back</button>'
          + '<button class="flowform-submit" id="ffSubmit">Send it</button>'
          + '</div>'
          + '</div>';
      }

      if (screen.type === 'confirmation') {
        var gp = function(cx, cy, r, teeth, th) {
          var d = '', ri = r, ro = r + th;
          for (var i = 0; i < teeth; i++) {
            var a = (Math.PI * 2 * i) / teeth - Math.PI / 2;
            var s = (Math.PI * 2) / teeth;
            var g = s * 0.12;
            d += (i === 0 ? 'M' : 'L');
            d += (cx + ri * Math.cos(a)).toFixed(1) + ',' + (cy + ri * Math.sin(a)).toFixed(1);
            d += 'L' + (cx + ri * Math.cos(a + g)).toFixed(1) + ',' + (cy + ri * Math.sin(a + g)).toFixed(1);
            d += 'L' + (cx + ro * Math.cos(a + g + s * 0.06)).toFixed(1) + ',' + (cy + ro * Math.sin(a + g + s * 0.06)).toFixed(1);
            d += 'L' + (cx + ro * Math.cos(a + s * 0.5 - s * 0.06)).toFixed(1) + ',' + (cy + ro * Math.sin(a + s * 0.5 - s * 0.06)).toFixed(1);
            d += 'L' + (cx + ri * Math.cos(a + s * 0.5 - g)).toFixed(1) + ',' + (cy + ri * Math.sin(a + s * 0.5 - g)).toFixed(1);
            d += 'L' + (cx + ri * Math.cos(a + s * 0.5 + g)).toFixed(1) + ',' + (cy + ri * Math.sin(a + s * 0.5 + g)).toFixed(1);
          }
          return d + 'Z';
        };
        var gears = [
          { cx: 30,  cy: 50, r: 18, t: 12, th: 6,   hub: 7,   cls: 'ff-g1', sw: 2,   clr: 'var(--slate-600)' },
          { cx: 62,  cy: 38, r: 14, t: 10, th: 5,   hub: 5.5, cls: 'ff-g2', sw: 1.8, clr: 'var(--accent)' },
          { cx: 90,  cy: 50, r: 16, t: 11, th: 5.5, hub: 6,   cls: 'ff-g3', sw: 1.8, clr: 'var(--slate-600)' },
          { cx: 118, cy: 40, r: 12, t: 9,  th: 4.5, hub: 4.5, cls: 'ff-g4', sw: 1.5, clr: 'var(--accent)' },
          { cx: 148, cy: 50, r: 17, t: 12, th: 5.5, hub: 6.5, cls: 'ff-g5', sw: 2,   clr: 'var(--slate-600)' },
          { cx: 76,  cy: 62, r: 8,  t: 8,  th: 3,   hub: 3,   cls: 'ff-g6', sw: 1.2, clr: 'var(--accent-hover)' },
          { cx: 130, cy: 62, r: 7,  t: 7,  th: 2.5, hub: 2.5, cls: 'ff-g7', sw: 1,   clr: 'var(--accent-hover)' }
        ];
        var svg = '<svg viewBox="10 18 160 60" fill="none" xmlns="http://www.w3.org/2000/svg">';
        for (var gi = 0; gi < gears.length; gi++) {
          var g = gears[gi];
          svg += '<g class="' + g.cls + '" style="transform-origin:' + g.cx + 'px ' + g.cy + 'px">';
          svg += '<path d="' + gp(g.cx, g.cy, g.r, g.t, g.th) + '" stroke="' + g.clr + '" stroke-width="' + g.sw + '" fill="none" stroke-linejoin="round"/>';
          svg += '<circle cx="' + g.cx + '" cy="' + g.cy + '" r="' + g.hub + '" stroke="' + g.clr + '" stroke-width="' + g.sw + '" fill="none"/>';
          svg += '<circle cx="' + g.cx + '" cy="' + g.cy + '" r="1.5" fill="' + g.clr + '"/>';
          svg += '</g>';
        }
        svg += '</svg>';
        html = '<div class="flowform-confirmation ff-fade-up">'
          + '<h3>Message received here in the jungle of Costa Rica. 🐒</h3>'
          + '<div class="ff-gears">' + svg + '</div>'
          + '<p>You\'ve got my gears turning. I\'ll be in touch within 48 hours.</p>'
          + '</div>';
      }

      ffCard.innerHTML = html;

      ffBackWrap.innerHTML = '';

      bindEvents();
    }

    function esc(str) {
      return str.replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/</g, '&lt;');
    }

    function bindEvents() {
      var screen = FF_SCREENS[step];

      ffCard.querySelectorAll('.flowform-option').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var val = btn.getAttribute('data-value');
          if (screen.type === 'single') {
            selections[screen.id] = val;
            btn.classList.add('selected');
            clearTimeout(advanceTimer);
            var skipToContact = val === "I'd rather just email you";
            var contactIdx = FF_SCREENS.findIndex(function(s) { return s.type === 'contact'; });
            advanceTimer = setTimeout(function() {
              direction = 1;
              step = skipToContact ? contactIdx : Math.min(step + 1, TOTAL - 1);
              stepHistory.push(step);
              render();
            }, 380);
          } else {
            var idx = multiSelections.indexOf(val);
            if (idx !== -1) {
              multiSelections.splice(idx, 1);
              btn.classList.remove('selected');
              btn.querySelector('.flowform-option-indicator').innerHTML = '';
            } else {
              multiSelections.push(val);
              btn.classList.add('selected');
              btn.querySelector('.flowform-option-indicator').innerHTML = '<svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M2.5 5L4.5 7L7.5 3.5" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>';
            }
            var nextBtn = document.getElementById('ffMultiNext');
            if (nextBtn) nextBtn.disabled = multiSelections.length === 0;
          }
        });
      });

      var multiNext = document.getElementById('ffMultiNext');
      if (multiNext) {
        multiNext.addEventListener('click', function() {
          if (multiSelections.length === 0) return;
          selections[screen.id] = multiSelections.slice();
          direction = 1;
          step++;
          stepHistory.push(step);
          multiSelections = [];
          render();
        });
      }

      var backBtn = document.getElementById('ffBack');
      if (backBtn) {
        backBtn.addEventListener('click', function() {
          clearTimeout(advanceTimer);
          direction = -1;
          if (stepHistory.length > 1) stepHistory.pop();
          step = stepHistory[stepHistory.length - 1];
          var targetScreen = FF_SCREENS[step];
          if (targetScreen.type === 'multi' && selections[targetScreen.id]) {
            multiSelections = selections[targetScreen.id].slice();
          }
          render();
        });
      }

      if (screen.type === 'contact') {
        var nameInput = document.getElementById('ffName');
        var emailInput = document.getElementById('ffEmail');
        var prefSelect = document.getElementById('ffPref');
        var phoneWrap = document.getElementById('ffPhoneWrap');
        var phoneInput = document.getElementById('ffPhone');
        var oneThingInput = document.getElementById('ffOneThing');
        var submitBtn = document.getElementById('ffSubmit');

        function syncContact() {
          contactData.name = nameInput.value;
          contactData.email = emailInput.value;
          contactData.contact_pref = prefSelect.value;
          if (phoneInput) contactData.phone = phoneInput.value;
          contactData.one_thing = oneThingInput.value;
        }

        [nameInput, emailInput, phoneInput, oneThingInput].forEach(function(el) {
          if (!el) return;
          el.addEventListener('input', syncContact);
          el.addEventListener('focus', function() {
            el.style.borderColor = 'var(--accent)';
            el.style.boxShadow = '0 0 0 3px rgba(101, 163, 13, 0.1)';
          });
          el.addEventListener('blur', function() {
            el.style.borderColor = '';
            el.style.boxShadow = '';
            syncContact();
          });
        });

        prefSelect.addEventListener('change', function() {
          contactData.contact_pref = prefSelect.value;
          phoneWrap.style.display = prefSelect.value === 'Phone' ? '' : 'none';
        });

        prefSelect.addEventListener('focus', function() {
          prefSelect.style.borderColor = 'var(--accent)';
          prefSelect.style.boxShadow = '0 0 0 3px rgba(101, 163, 13, 0.1)';
        });
        prefSelect.addEventListener('blur', function() {
          prefSelect.style.borderColor = '';
          prefSelect.style.boxShadow = '';
        });

        submitBtn.addEventListener('click', function() {
          syncContact();
          var errs = {};
          if (!contactData.name.trim()) errs.name = true;
          if (!contactData.email.trim() || contactData.email.indexOf('@') === -1) errs.email = true;
          if (contactData.contact_pref === 'Phone' && !contactData.phone.trim()) errs.phone = true;

          document.getElementById('ffNameErr').innerHTML = errs.name ? '<span class="ff-error-msg">Name is required</span>' : '';
          document.getElementById('ffEmailErr').innerHTML = errs.email ? '<span class="ff-error-msg">Valid email is required</span>' : '';
          var phoneErr = document.getElementById('ffPhoneErr');
          if (phoneErr) phoneErr.innerHTML = errs.phone ? '<span class="ff-error-msg">Phone number is required</span>' : '';

          if (errs.name) nameInput.classList.add('ff-error');
          else nameInput.classList.remove('ff-error');
          if (errs.email) emailInput.classList.add('ff-error');
          else emailInput.classList.remove('ff-error');
          if (phoneInput && errs.phone) phoneInput.classList.add('ff-error');
          else if (phoneInput) phoneInput.classList.remove('ff-error');

          if (Object.keys(errs).length) {
            ffCard.classList.add('ff-shake');
            ffCard.addEventListener('animationend', function() {
              ffCard.classList.remove('ff-shake');
            }, { once: true });
            return;
          }

          var payload = {
            'form-name': 'contact',
            slow_down: selections.slow_down || '',
            building: Array.isArray(selections.building) ? selections.building.join(', ') : (selections.building || ''),
            stage: selections.stage || '',
            urgency: selections.urgency || '',
            budget: selections.budget || '',
            name: contactData.name.trim(),
            email: contactData.email.trim(),
            contact_pref: contactData.contact_pref || 'Email',
            phone: contactData.phone.trim(),
            one_thing: contactData.one_thing.trim(),
            submitted_at: new Date().toISOString(),
          };

          submitBtn.disabled = true;
          submitBtn.textContent = 'Sending…';

          fetch('/', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: new URLSearchParams(payload).toString(),
          })
          .then(function(res) {
            if (!res.ok) throw new Error('Network response was not ok');
            direction = 1;
            step = TOTAL - 1;
            render();
          })
          .catch(function(err) {
            console.error('Form submission error:', err);
            submitBtn.disabled = false;
            submitBtn.textContent = 'Send it';
            var errDiv = document.createElement('div');
            errDiv.className = 'ff-error-msg';
            errDiv.style.textAlign = 'center';
            errDiv.style.marginTop = 'var(--space-4)';
            errDiv.textContent = 'Something went wrong. Please try again.';
            ffCard.appendChild(errDiv);
            setTimeout(function() { errDiv.remove(); }, 4000);
          });
        });
      }
    }

    render();
  })();
</script>
{% endblock %}
